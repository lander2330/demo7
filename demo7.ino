// Sketch: demo7.ino
// Version: Version 2026.05.27
// Author: Larry Anderson
//
// This ESP32 microcontroller project shows how to display
// multiple bitmaps in series to provide an animation display
// on an ssd1306 oled display wired to an ESP32.
//
// Below are the steps I used to capture and prepare the monochrome bitmaps
// for display on my SSD1306 OLED display.
//
// You will use different, but similar steps to capture
// small monochrome bitmap images (.bmp) and use the image2cpp
// website to convert them to hexbyte codes that your sketch
// can then use display.drawBitmap to display the bitmaps on
// your ESP32 oled display.
//
// For this demonstration, the sketch repeatedly displays a
// series of 5 slightly different images of a fan blades that
// are rotated several degrees that simulate a spinning fan.
//
// I took a single image and converted it to monochrome black
// and white. Then resized it to 64x48. Then made copies of the
// image and used photo editing software to rotate each image
// several degrees to end up with 5 images with the fan blades
// appearing at different stages of rotating in a circle of
// 360 degrees. When shown slowly in series, it appears as
// if the fan is spinning.
//
// 1. Launch American Systems Print Screen Deluxe on Windows PC
//    This is a tool that I use to capture a designated 
//    region on the desktop pc monitor. Instead, you might
//    use your operating systems keyboard screen capture 
//    feature if it has one.
//
// 2. Use Google to locate the desired all black and white image
//    Keep in mind that you will be reducing the size to 
//    something like 128x64 or 64x48 so the image will be
//    very primitive in its detail.
//
// 3. Use Print Screen Deluxe capture key to copy the image
//    as it is displayed on the screen.
//
// 4. Launch Corel PaintShop Pro and switch to the edit tab.
//    Use whatever image editing software you have that
//    supports features for reducing the image to a 2 color
//    monochrome image and resizing the image to a small
//    thumbnail like 128x64 or 64x48 pixels.
//
// 5. Use Edit->Paste as new image
//
// 6. Use Image->Decrease color depth->2 color palette
//
// 7. Use Image->Resize and set "By pixe" and "Lock aspect ratio"
//    and "height to 48
//
//    Resize the image as a 2 color (monochrome) .bmp file
//    at 64 x 48.  Though the image can be 128 x 64, I chose
//    to support the smaller size so I can display text above 
//    and to the side of image on the oled display.
//
// 8. Then useEdit->copy to place the resized image into the clipboard
//
// 9. File->New to create a white 2 color empty image 64x48
//
// 10.Edit->Paste as new layer
//
// 11.Save As and specify a filename.bmp  
//
// 12.Use the image2cpp website to read the
//    filename.bmp file to generate the hex byte codes.
//    Best to check the imvert option so the
//    image appears on a black background 
//    opposed to the oled's blue background.
//
// 13.Copy and paste the hex byte codes into the arduino sketch

#include <Arduino.h>
#define SDA_PIN 21
#define SCL_PIN 22

// SSD1306 OLED display wiring to the
// Board: ESP32C6 Dev Module (specifically Espressif Systems ESP32-C6-DEVKITC-1-N8 Microcontroller)
// - --> GND
// + --> 5V
// SCL --> 21
// SDA --> 22

// the following statements are for the SSD1306 OLED display 
#include <Adafruit_GFX.h>
#include <Adafruit_SSD1306.h>
#define SCREEN_WIDTH 128 // OLED display width, in pixels
#define SCREEN_HEIGHT 64 // OLED display height, in pixels
// Declaration for an SSD1306 display connected to I2C (SDA, SCL pins)
#define OLED_RESET     -1 // Reset pin # (or -1 if sharing Arduino reset pin)
Adafruit_SSD1306 display(SCREEN_WIDTH, SCREEN_HEIGHT, &Wire, OLED_RESET);
boolean oledInitialized = false;

