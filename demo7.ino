void setup()
  {
  Wire.begin(SDA_PIN,SCL_PIN);  // microcontroller pins wired to the OLED display
  }

void loop()
  {
  // show the 5 fan images in series with a 50 millisecond display between each display 
  // do that 20 times and then take a 1 second break before repeating the process indefinitely 
  for (int i=1; i <= 20; i++)
    {
    oledDisplayBitmap("DEMO7","       Swamp","       Cooler","       Control","       Version","       1.0", 12, 16, fan1, 64, 48, 50);
    oledDisplayBitmap("DEMO7","       Swamp","       Cooler","       Control","       Version","       1.0", 12, 16, fan2, 64, 48, 50);
    oledDisplayBitmap("DEMO7","       Swamp","       Cooler","       Control","       Version","       1.0", 12, 16, fan3, 64, 48, 50);
    oledDisplayBitmap("DEMO7","       Swamp","       Cooler","       Control","       Version","       1.0", 12, 16, fan4, 64, 48, 50);
    oledDisplayBitmap("DEMO7","       Swamp","       Cooler","       Control","       Version","       1.0", 12, 16, fan5, 64, 48, 50);
    }
  delay(1000);  
  }

void oledDisplayBitmap(char * title, char * msg1, char * msg2, char * msg3, char * msg4, char * msg5, int hposition, int vposition, const unsigned char byteCodes[], int imageWidth, int imageHeight, int delayMilliseconds)
  {
  if (delayMilliseconds < 0)
    {
    unsigned long ms = millis();
    while ((millis() - ms) < (delayMilliseconds * -1))
      { 
      delay(100);       
      }    
    }   
  oledClearDisplay();
  display.drawBitmap(hposition,vposition,byteCodes,imageWidth,imageHeight,WHITE);
  if (strlen(msg5) > 0)
    {
    oledPrint(0,0,2,title);
    oledPrint(24,0,1,msg1);
    oledPrint(32,0,1,msg2);
    oledPrint(40,0,1,msg3);
    oledPrint(48,0,1,msg4);
    oledPrint(56,0,1,msg5);     
    }
  else if (strlen(msg4) > 0)
    {
    oledPrint(0,0,2,title);
    oledPrint(24,0,1,msg1);
    oledPrint(34,0,1,msg2);
    oledPrint(42,0,1,msg3);
    oledPrint(50,0,1,msg4);
    }
  else if (strlen(msg3) > 0)
    {
    oledPrint(0,0,2,title);
    oledPrint2(24,0,1,msg1);
    oledPrint2(40,0,1,msg2);
    oledPrint2(56,0,1,msg3);        
    }
  else if (strlen(msg2) > 0)
    {
    oledPrint(0,0,2,title);
    oledPrint2(24,0,2,msg1);
    oledPrint2(48,0,2,msg2);       
    }
  else
    {
    oledPrint(0,0,2,title);  
    oledPrint2(36,0,2,msg1);    
    } 
  oledShowDisplay();
  if (delayMilliseconds > 0)
    {
    unsigned long ms = millis();
    while ((millis() - ms) < delayMilliseconds)
      { 
      delay(100); 
      }    
    }     
  }  

void oledClearDisplay()
  {
  if (!oledInitialized)
    {
    if (!display.begin(SSD1306_SWITCHCAPVCC, 0x3C))
      { // address 0x3D for 128x64
      //Serial.println(F("OLED failed!"));
      while (true);
      }
    display.clearDisplay();       // clear oled display buffer
    display.display();            // display the cleared buffer
    display.setTextColor(WHITE);  // draw in white text
    display.cp437(true);          // use full 256 char 'Code Page 437' font
    oledInitialized = true;
    }
  display.clearDisplay();
  }

void oledPrint(int row, int align, int textSize, char * text)
  {
  display.setTextSize(textSize);
  if (align == 0)       // center
    display.setCursor(SCREEN_WIDTH / 2 - (((strlen(text)) * (textSize * 6)) / 2), row);
  else if (align == 1)  // left
    display.setCursor(0, row);
  else                  // right
    display.setCursor(SCREEN_WIDTH - ((strlen(text) * (textSize * 6))), row);
  display.print(text);
  }

void oledPrint2(int row, int align, int textSize, char * text)
  {
  display.setTextSize(textSize);
  if (align == 0)       // center
    display.setCursor(96-(((strlen(text))*(textSize*6))/2),row);
  else if (align == 1)  // left     
    display.setCursor(64,row);
  else                  // right
    display.setCursor(128-((strlen(text)*(textSize*6))),row);    
  display.print(text);
  }    

void oledShowDisplay()
  {
  display.display();
  }

